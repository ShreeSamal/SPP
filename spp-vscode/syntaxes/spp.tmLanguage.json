{
  "name": "S++",
  "scopeName": "source.spp",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#literals" },
    { "include": "#functions" },
    { "include": "#variables" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {

    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.spp",
          "match": "//.*$"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.spp",
          "match": "\\b(if|else|while|return)\\b"
        },
        {
          "name": "keyword.declaration.spp",
          "match": "\\b(let|fn)\\b"
        },
        {
          "name": "keyword.other.spp",
          "match": "\\b(print)\\b"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "storage.type.spp",
          "match": "\\b(int|float|bool|void)\\b"
        }
      ]
    },

    "literals": {
      "patterns": [
        {
          "name": "constant.language.boolean.spp",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.numeric.float.spp",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.spp",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "functions": {
      "patterns": [
        {
          "comment": "function definition: fn name(",
          "name": "entity.name.function.spp",
          "match": "(?<=\\bfn\\s)([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
        },
        {
          "comment": "function call: name(",
          "name": "entity.name.function.call.spp",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
        }
      ]
    },

    "variables": {
      "patterns": [
        {
          "comment": "variable declaration: let name",
          "name": "variable.other.spp",
          "match": "(?<=\\blet\\s)([a-zA-Z_][a-zA-Z0-9_]*)"
        },
        {
          "comment": "parameter: name:",
          "name": "variable.parameter.spp",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*:)"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.spp",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.comparison.spp",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arrow.spp",
          "match": "->"
        },
        {
          "name": "keyword.operator.assignment.spp",
          "match": "(?<!=)=(?!=)"
        },
        {
          "name": "keyword.operator.arithmetic.spp",
          "match": "(\\+|-|\\*|/|%)"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.block.spp",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.parameters.spp",
          "match": "[()]"
        },
        {
          "name": "punctuation.separator.spp",
          "match": "[,;:]"
        }
      ]
    }

  }
}
